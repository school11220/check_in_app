generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model AuditLog {
  id         String   @id
  action     String
  resource   String
  resourceId String?
  details    Json?
  userId     String
  userName   String
  userRole   String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([resource])
  @@index([userId, createdAt])
}

model User {
  id               String   @id // Clerk user ID
  email            String   @unique
  firstName        String?
  lastName         String?
  name             String?
  password         String?
  imageUrl         String?
  role             String   @default("UNAUTHORIZED")
  assignedEventIds String[] @default([])
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  organizedEvents  Event[]  @relation("OrganizerEvents")
  tickets          Ticket[]

  @@index([role])
  @@index([isActive, role])
}

model Event {
  id                   String        @id
  name                 String
  description          String?
  date                 DateTime
  startTime            String        @default("09:00")
  endTime              String        @default("18:00")
  venue                String?
  address              String?
  price                Int           @default(0)
  entryFee             Int           @default(0)
  prizePool            Int           @default(0)
  category             String        @default("other")
  imageUrl             String?
  capacity             Int           @default(100)
  soldCount            Int           @default(0)
  isActive             Boolean       @default(true)
  isFeatured           Boolean       @default(false)
  schedule             Json          @default("[]")
  speakers             Json          @default("[]")
  sponsors             Json          @default("[]")
  tags                 String[]      @default([])
  organizer            String?
  organizerId          String?
  contactEmail         String?
  contactPhone         String?
  termsAndConditions   String?
  registrationDeadline String?
  earlyBirdEnabled     Boolean       @default(false)
  earlyBirdPrice       Int           @default(0)
  earlyBirdDeadline    String?
  sendReminders        Boolean       @default(false)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  registrationFields   Json          @default("[]")
  organizerVideoLink   String?
  videoLink            String?
  gallery              Json          @default("[]")
  // New fields for per-event branding
  brandPrimaryColor    String?       // override theme primary color for this event
  brandAccentColor     String?
  brandLogoUrl         String?
  brandBannerUrl       String?
  customDomain         String?       @unique
  PricingRule          PricingRule[]
  Review               Review[]
  Session              Session[]
  Ticket               Ticket[]
  CertificateTemplate  CertificateTemplate?
  EventBrand           EventBrand?
  AddOn                AddOn[]
  GroupRegistration    GroupRegistration[]
  WaitlistEntry        WaitlistEntry[]
  OrganizerUser        User?         @relation("OrganizerEvents", fields: [organizerId], references: [id], onDelete: SetNull)

  @@index([category])
  @@index([isActive])
  @@index([organizerId])
  @@index([isActive, date])
  @@index([isFeatured, isActive])
  @@index([date])
}

model Integration {
  id        String   @id
  provider  String   @unique
  name      String
  type      String
  isEnabled Boolean  @default(false)
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRule {
  id              String   @id
  eventId         String
  triggerType     String
  triggerValue    Int
  adjustmentType  String
  adjustmentValue Int
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([active])
  @@index([eventId])
  @@index([eventId, active])
}

model Review {
  id        String   @id
  eventId   String
  userName  String
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  Event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([eventId, createdAt])
  @@index([rating])
}

model Session {
  id              String   @id
  eventId         String
  title           String
  description     String?
  type            String   @default("talk")
  speakerName     String?
  speakerRole     String?
  startTime       String
  endTime         String
  date            String
  capacity        Int      @default(100)
  registeredCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([eventId, date, startTime])
}

model SiteConfig {
  id        String   @id @default("default")
  settings  Json     @default("{}")
  templates Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  surveys   Json     @default("[]")
}

model Ticket {
  id                String       @id
  name              String
  email             String?
  phone             String?
  eventId           String
  status            String       @default("pending")
  token             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  amountPaid        Int          @default(0)
  grossAmount       Int          @default(0)
  discountAmount    Int          @default(0)
  refundedAmount    Int          @default(0)
  paymentMethod     String?
  checkedIn         Boolean      @default(false)
  checkedInAt       DateTime?
  checkedInBy       String?
  certificateSent   Boolean      @default(false)
  purchaseGroupId   String?
  cancelledAt       DateTime?
  lastDeliveredAt   DateTime?
  deliveryCount     Int          @default(0)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  customAnswers     Json         @default("{}")
  promoCodeId       String?
  userId            String?
  Event             Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  User              User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  CheckInLogs       CheckInLog[]
  DeliveryLogs      TicketDeliveryLog[]

  @@index([email])
  @@index([eventId])
  @@index([razorpayOrderId])
  @@index([status])
  @@index([token])
  @@index([userId])
  @@index([paymentMethod])
  // Composite indexes added for dashboard counters and analytics
  @@index([eventId, status])
  @@index([eventId, checkedIn])
  @@index([eventId, checkedIn, status])
  @@index([eventId, createdAt])
  @@index([eventId, status, createdAt])
  @@index([status, createdAt])
  @@index([purchaseGroupId])
}

model CheckInLog {
  id            String   @id @default(uuid())
  ticketId      String
  eventId       String
  action        String
  performedBy   String
  performedRole String
  ipAddress     String?
  userAgent     String?
  deviceId      String?
  reason        String?
  checksum      String
  syncedAt      DateTime?
  createdAt     DateTime @default(now())
  ticket        Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([eventId])
  @@index([createdAt])
  @@index([performedBy])
  @@index([eventId, createdAt])
  @@index([eventId, action])
}

model TicketDeliveryLog {
  id          String   @id @default(uuid())
  ticketId    String
  channel     String
  recipient   String?
  success     Boolean
  error       String?
  requestedBy String?
  createdAt   DateTime @default(now())
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([channel])
  @@index([createdAt])
  @@index([ticketId, createdAt])
}

model SecurityEvent {
  id        String   @id @default(uuid())
  type      String
  key       String
  ticketId  String?
  eventId   String?
  ipAddress String?
  userAgent String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([key])
  @@index([ticketId])
  @@index([eventId])
  @@index([createdAt])
  @@index([type, createdAt])
}

model PromoCodeRecord {
  id              String    @id @default(uuid())
  code            String
  discountType    String
  discountValue   Int
  maxUses         Int       @default(100)
  usedCount       Int       @default(0)
  maxUsesPerUser  Int       @default(1)
  minTickets      Int       @default(1)
  stackable       Boolean   @default(false)
  eventIds        String[]  @default([])
  expiresAt       DateTime
  startsAt        DateTime  @default(now())
  isActive        Boolean   @default(true)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([code])
  @@index([code])
  @@index([isActive])
  @@index([expiresAt])
  @@index([isActive, expiresAt])
}

model PromoUsage {
  id          String   @id @default(uuid())
  promoCode   String
  ticketId    String
  userId      String?
  eventId     String
  discount    Int
  createdAt   DateTime @default(now())

  @@index([promoCode])
  @@index([userId])
  @@index([eventId])
  @@index([promoCode, createdAt])
}

model CertificateTemplate {
  id              String   @id @default(cuid())
  name            String
  eventId         String?  @unique
  Event           Event?   @relation(fields: [eventId], references: [id])
  bgImage         String?
  elements        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Per-event branding overrides (logo, colors, copy, custom CSS)
model EventBrand {
  id              String   @id @default(cuid())
  eventId         String   @unique
  Event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String?  // hex (#RRGGBB)
  accentColor     String?
  backgroundColor String?
  textColor       String?
  customCss       String?  // scoped CSS injected on the public event page
  customDomain    String?  @unique
  ogImageUrl      String?
  tagline         String?
  supportEmail    String?
  supportPhone    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Per-event add-ons (merch, food, parking) selectable at checkout
model AddOn {
  id            String   @id @default(cuid())
  eventId       String
  Event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  priceInPaise  Int      // stored in paise, same convention as Ticket price
  currency      String   @default("INR")
  maxQuantity   Int      @default(100)
  soldQuantity  Int      @default(0)
  isActive      Boolean  @default(true)
  imageUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([eventId])
  @@index([eventId, isActive])
}

// Group registrations bundle multiple tickets under one purchase
model GroupRegistration {
  id              String   @id @default(cuid())
  eventId         String
  Event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  purchaseGroupId String   @unique
  primaryName     String
  primaryEmail    String
  primaryPhone    String?
  memberCount     Int      @default(1)
  totalAmount     Int      @default(0)
  status          String   @default("pending") // pending|paid|cancelled|refunded
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([eventId])
  @@index([eventId, status])
  @@index([primaryEmail])
}

// Waitlist for sold-out events
model WaitlistEntry {
  id           String   @id @default(cuid())
  eventId      String
  Event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name         String
  email        String
  phone        String?
  ticketCount  Int      @default(1)
  status       String   @default("waiting") // waiting|notified|converted|expired
  notifiedAt   DateTime?
  notifiedVia  String?  // 'email' | 'sms'
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([eventId])
  @@index([eventId, status])
  @@index([email])
  @@index([eventId, status, createdAt])
}

// Push notification subscriptions (PWA)
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?  // optional Clerk user id
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastUsedAt DateTime?

  @@index([userId])
}

// Reminder job queue (T-7d / T-1d / T-1h)
model ReminderJob {
  id          String    @id @default(cuid())
  ticketId    String
  eventId     String
  userId      String?
  type        String    // 'T-7d' | 'T-1d' | 'T-1h' | 'custom'
  scheduledAt DateTime
  status      String    @default("pending") // pending|sent|failed|skipped
  channel     String    @default("email")   // email|sms|push
  attempts    Int       @default(0)
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
  @@index([eventId])
  @@index([ticketId])
  @@index([status])
}
