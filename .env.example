# ==================================
# EventHub Environment Variables
# ==================================
# Copy this file to .env.local for development.
# In Vercel, add the same keys under Project Settings > Environment Variables.

# =============
# CORE APP
# =============
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =============
# DATABASE (REQUIRED)
# =============
# Keep both values identical for compatibility.
POSTGRES_PRISMA_URL=postgresql://user:password@host:5432/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# =============
# AUTH (CLERK) (REQUIRED)
# =============
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# =============
# SECURITY (RECOMMENDED / REQUIRED FOR SOME FLOWS)
# =============
# Protects /api/bootstrap-admin. Set a long random value if this route is used.
ADMIN_BOOTSTRAP_SECRET=change-this-very-long-random-secret

# Used for ticket checksum/signature flows.
TICKET_SECRET_KEY=change-this-very-long-random-secret

# Protects cron/scheduled endpoints when enabled.
CRON_SECRET=change-this-very-long-random-secret

# =============
# PAYMENTS: RAZORPAY (REQUIRED IF USING RAZORPAY)
# =============
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# =============
# PAYMENTS: PHONEPE (OPTIONAL)
# =============
PHONEPE_API_URL=https://api-preprod.phonepe.com/apis/pg-sandbox
PHONEPE_MERCHANT_ID=your-phonepe-merchant-id
PHONEPE_SALT_KEY=your-phonepe-salt-key
PHONEPE_SALT_INDEX=1

# =============
# EMAIL (SET ONE METHOD)
# =============
# Option A: Gmail
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Option B: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SENDER_EMAIL=noreply@yourdomain.com
SENDER_NAME=EventHub

# =============
# RATE LIMITING (OPTIONAL, RECOMMENDED IN PROD)
# =============
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# =============
# OPTIONAL: SMS
# =============
FAST2SMS_API_KEY=your-fast2sms-api-key

# =============
# PUSH NOTIFICATIONS (OPTIONAL)
# =============
# Public VAPID key for the PWA service worker. Generate with:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
